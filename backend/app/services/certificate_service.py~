from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, and_
from sqlalchemy.orm import selectinload

from app.models.certificate import CourseCertificate
from app.models.lesson import LessonCompletion, Lesson
from app.models.course import Course


async def check_course_completion(db: AsyncSession, student_id: int, course_id: int) -> bool:
    """Barcha darslar tugatilganmi?"""
    # Kurs darslarining umumiy soni
    total_q = await db.execute(
        select(Lesson).where(Lesson.course_id == course_id)
    )
    total_lessons = total_q.scalars().all()
    if not total_lessons:
        return False

    # Student tugatgan darslar soni
    completed_q = await db.execute(
        select(LessonCompletion).where(
            and_(
                LessonCompletion.student_id == student_id,
                LessonCompletion.lesson_id.in_([l.id for l in total_lessons])
            )
        )
    )
    completed = completed_q.scalars().all()
    return len(completed) == len(total_lessons)


async def check_min_points(db: AsyncSession, student_id: int, course_id: int) -> bool:
    """Student kurs uchun minimum ball to'plaganmi?"""
    course_q = await db.execute(select(Course).where(Course.id == course_id))
    course = course_q.scalar_one_or_none()
    if not course:
        return False

    # Student modelidan to'plangan ballarni olish
    from app.models.user import Student
    student_q = await db.execute(select(Student).where(Student.id == student_id))
    student = student_q.scalar_one_or_none()
    if not student:
        return False

    # min_points = kurs max_points ning 60% i
    min_required = int(course.max_points * 0.6)
    return student.total_points >= min_required


async def award_certificate(
    db: AsyncSession, student_id: int, course_id: int
) -> CourseCertificate | None:
    """
    Shartlar bajarilgan bo'lsa sertifikat beradi.
    Allaqachon mavjud bo'lsa None qaytaradi.
    """
    # Avval mavjudligini tekshirish
    existing_q = await db.execute(
        select(CourseCertificate).where(
            and_(
                CourseCertificate.student_id == student_id,
                CourseCertificate.course_id == course_id
            )
        )
    )
    if existing_q.scalar_one_or_none():
        return None  # Allaqachon bor

    # Ikki shartni tekshirish
    all_done = await check_course_completion(db, student_id, course_id)
    enough_points = await check_min_points(db, student_id, course_id)

    if not (all_done and enough_points):
        return None

    cert = CourseCertificate(student_id=student_id, course_id=course_id)
    db.add(cert)
    await db.commit()
    await db.refresh(cert)
    return cert


async def get_my_certificates(db: AsyncSession, student_id: int) -> list[CourseCertificate]:
    """Student sertifikatlarini kurs ma'lumoti bilan qaytarish"""
    q = await db.execute(
        select(CourseCertificate)
        .options(selectinload(CourseCertificate.course))
        .where(CourseCertificate.student_id == student_id)
    )
    return q.scalars().all()


async def get_course_certificate(
    db: AsyncSession, student_id: int, course_id: int
) -> CourseCertificate | None:
    """Muayyan kurs sertifikatini olish"""
    q = await db.execute(
        select(CourseCertificate)
        .options(selectinload(CourseCertificate.course))
        .where(
            and_(
                CourseCertificate.student_id == student_id,
                CourseCertificate.course_id == course_id
            )
        )
    )
    return q.scalar_one_or_none()