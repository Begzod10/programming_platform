from sqlalchemy import select, delete, update
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy.orm import selectinload
from app.models.group import Group
from app.schemas.group import GroupCreate, GroupUpdate


class GroupService:
    def __init__(self, db: AsyncSession):
        self.db = db

    async def create_group(self, group_data: GroupCreate):
        """Yangi guruh yaratish"""
        new_group = Group(**group_data.model_dump())
        self.db.add(new_group)
        await self.db.commit()
        await self.db.refresh(new_group)
        return new_group

    async def get_all_groups(self):
        """Barcha guruhlarni ichidagi talabalari bilan birga olish"""
        query = select(Group).options(selectinload(Group.students))
        result = await self.db.execute(query)
        return result.scalars().all()

    async def update_group(self, group_id: int, group_data: GroupUpdate):
        """Guruh ma'lumotlarini yangilash"""
        update_data = group_data.model_dump(exclude_unset=True)
        if not update_data:
            return None

        query = (
            update(Group)
            .where(Group.id == group_id)
            .values(**update_data)
            .returning(Group)
        )
        result = await self.db.execute(query)
        await self.db.commit()
        return result.scalar_one_or_none()

    async def delete_group(self, group_id: int) -> bool:
        """Guruhni o'chirish"""
        try:
            query = delete(Group).where(Group.id == group_id)
            result = await self.db.execute(query)
            await self.db.commit()

            # Agar kamida bitta qator o'chirilgan bo'lsa True qaytaradi
            return result.rowcount > 0
        except Exception as e:
            await self.db.rollback()
            print(f"Guruhni o'chirishda xatolik: {e}")
            return False
