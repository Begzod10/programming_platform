from fastapi import APIRouter, Depends, Query, HTTPException, status
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, or_
from typing import List

from app.db.session import get_db
from app.schemas.course import CourseRead, CourseCreate, CourseUpdate
from app.models.course import Course
from app.services.auth_service import get_current_student
from app.models.user import Student

router = APIRouter()


@router.post(
    "/",
    response_model=CourseRead,
    status_code=status.HTTP_201_CREATED,
    summary="Create a new course",
)
async def create_course(
        payload: CourseCreate,
        db: AsyncSession = Depends(get_db),
):
    new_course = Course(**payload.model_dump())
    db.add(new_course)
    await db.commit()
    await db.refresh(new_course)
    return new_course


@router.get(
    "/",
    response_model=List[CourseRead],
    summary="Get all courses",
)
async def get_courses(
        skip: int = Query(0, ge=0),
        limit: int = Query(10, ge=1, le=100),
        search: str = Query(None),
        db: AsyncSession = Depends(get_db),
):
    query = select(Course)

    if search:
        query = query.where(
            or_(
                Course.title.ilike(f"%{search}%"),
                Course.description.ilike(f"%{search}%"),
            )
        )

    result = await db.execute(query.offset(skip).limit(limit))
    return result.scalars().all()


@router.get(
    "/{course_id}",
    response_model=CourseRead,
    summary="Get a course by ID",
)
async def get_course(course_id: int, db: AsyncSession = Depends(get_db)):
    result = await db.execute(select(Course).where(Course.id == course_id))
    course = result.scalar_one_or_none()
    if not course:
        raise HTTPException(status_code=404, detail="Kurs topilmadi")
    return course


@router.put(
    "/{course_id}",
    response_model=CourseRead,
    summary="Update a course by ID",
)
async def update_course(
        course_id: int,
        payload: CourseUpdate,
        db: AsyncSession = Depends(get_db),
):
    result = await db.execute(select(Course).where(Course.id == course_id))
    course = result.scalar_one_or_none()
    if not course:
        raise HTTPException(status_code=404, detail="Kurs topilmadi")

    for key, value in payload.model_dump(exclude_unset=True).items():
        setattr(course, key, value)

    await db.commit()
    await db.refresh(course)
    return course


@router.delete(
    "/{course_id}",
    status_code=status.HTTP_200_OK,
    summary="Delete a course by ID",
)
async def delete_course(course_id: int, db: AsyncSession = Depends(get_db)):
    result = await db.execute(select(Course).where(Course.id == course_id))
    course = result.scalar_one_or_none()
    if not course:
        raise HTTPException(status_code=404, detail="Kurs topilmadi")

    await db.delete(course)
    await db.commit()
    return {"message": "Kurs o'chirildi"}


@router.post(
    "/{course_id}/enroll",
    status_code=status.HTTP_200_OK,
    summary="Enroll in a course",
)
async def enroll_course(
        course_id: int,
        current_student: Student = Depends(get_current_student),
        db: AsyncSession = Depends(get_db),
):
    result = await db.execute(select(Course).where(Course.id == course_id))
    course = result.scalar_one_or_none()
    if not course:
        raise HTTPException(status_code=404, detail="Kurs topilmadi")

    if course in current_student.enrolled_courses:
        raise HTTPException(status_code=400, detail="Siz allaqachon bu kursga yozilgansiz")

    current_student.enrolled_courses.append(course)
    await db.commit()
    return {"message": f"'{course.title}' kursiga muvaffaqiyatli yozildingiz"}


@router.delete(
    "/{course_id}/unenroll",
    status_code=status.HTTP_200_OK,
    summary="Unenroll from a course",
)
async def unenroll_course(
        course_id: int,
        current_student: Student = Depends(get_current_student),
        db: AsyncSession = Depends(get_db),
):
    result = await db.execute(select(Course).where(Course.id == course_id))
    course = result.scalar_one_or_none()
    if not course:
        raise HTTPException(status_code=404, detail="Kurs topilmadi")

    if course not in current_student.enrolled_courses:
        raise HTTPException(status_code=400, detail="Siz bu kursga yozilmagansiz")

    current_student.enrolled_courses.remove(course)
    await db.commit()
    return {"message": f"'{course.title}' kursidan chiqildingiz"}
